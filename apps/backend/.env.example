# ─── Base de données ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/cecj_db"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change_me"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change_me"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Serveur ──────────────────────────────────────────────────────────────────
PORT=3001
# development (local) | production
NODE_ENV=development

# Origines autorisées (CORS), séparées par des virgules
CORS_ORIGINS="http://localhost:3000"

# ─── Fichiers uploadés ────────────────────────────────────────────────────────
# URL publique servant /api/v1/uploads/*. OPTIONNEL : par défaut, le code choisit
# selon NODE_ENV (production → domaine public, sinon → http://localhost:<PORT>).
# Décommenter pour forcer une origine explicite.
# BACKEND_URL="https://api.campdejesusbelairfizi.com"
